<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">

    <!-- Razorpay keys (demo setup) -->
    <context-param>
        <param-name>razorpayKeyId</param-name>
        <param-value>YOUR_KEY_ID</param-value>
    </context-param>
    <context-param>
        <param-name>razorpayKeySecret</param-name>
        <param-value>YOUR_KEY_SECRET</param-value>
    </context-param>

    <!-- Optional: UPI QR (for display on payment page) -->
    <context-param>
        <param-name>upiVpa</param-name>
        <param-value>yourvpa@upi</param-value>
    </context-param>
    <context-param>
        <param-name>upiName</param-name>
        <param-value>Smart Library</param-value>
    </context-param>
    
    <!-- Login Servlet Mapping -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.library.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet Mapping -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.library.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlet Mapping -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.library.controller.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/AdminServlet</url-pattern>
    </servlet-mapping>

    <!-- Librarian Servlet Mapping -->
    <servlet>
        <servlet-name>LibrarianServlet</servlet-name>
        <servlet-class>com.library.controller.LibrarianServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LibrarianServlet</servlet-name>
        <url-pattern>/LibrarianServlet</url-pattern>
    </servlet-mapping>

    <!-- User Servlet Mapping -->
    <servlet>
        <servlet-name>UserServlet</servlet-name>
        <servlet-class>com.library.controller.UserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserServlet</servlet-name>
        <url-pattern>/UserServlet</url-pattern>
    </servlet-mapping>

    <!-- Profile Servlet Mapping -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.library.controller.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </servlet-mapping>

    <!-- Report Servlet Mapping -->
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.library.controller.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

    <!-- Payment Servlet Mapping -->
    <servlet>
        <servlet-name>PaymentServlet</servlet-name>
        <servlet-class>com.library.controller.PaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PaymentServlet</servlet-name>
        <url-pattern>/PaymentServlet</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
